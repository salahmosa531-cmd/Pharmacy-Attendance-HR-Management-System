+      LoggingService.instance.info('SettingsService', '[SETTINGS_FOREGROUND] App resumed, reloading settings');
+      await reloadSettings();
+    });
+    
+    WidgetsBinding.instance.addObserver(_lifecycleObserver!);
+  }
